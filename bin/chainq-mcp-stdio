#!/usr/bin/env bash
# Dedicated launcher for the chainq MCP server over stdio.
#
# Goes straight from node -> tsx CLI -> the chainq CLI bin, so the only
# output on stdout is JSON-RPC. No pnpm wrapping layers.
#
# Intended to be invoked by `claude mcp add chainq -- /abs/path/to/this`.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
NODE_BIN="${NODE_BIN:-$(command -v node)}"
TSX_CLI="${TSX_CLI:-${REPO_ROOT}/node_modules/tsx/dist/cli.mjs}"
CLI_BIN="${CHAINQ_CLI_BIN:-${REPO_ROOT}/packages/cli/src/bin.ts}"

if [ ! -x "$NODE_BIN" ]; then
  echo "[chainq-mcp-stdio] node not found" >&2
  exit 1
fi
if [ ! -f "$TSX_CLI" ]; then
  echo "[chainq-mcp-stdio] tsx CLI missing at $TSX_CLI — run \`pnpm install\` in $REPO_ROOT" >&2
  exit 1
fi

export CHAINQ_DATA_DIR="${CHAINQ_DATA_DIR:-${REPO_ROOT}/data}"

exec "$NODE_BIN" "$TSX_CLI" "$CLI_BIN" mcp serve
