{
  "name": "@chainq/cli",
  "version": "0.0.0",
  "private": true,
  "description": "Standalone CLI for chainq (thin wrapper over the MCP server).",
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "chainq": "./src/bin.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
