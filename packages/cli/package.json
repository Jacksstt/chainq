    "@chainq/mcp-server": "workspace:*",
    "@chainq/snapshot": "workspace:*",
    "@duckdb/node-api": "1.5.2-r.1",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "license": "MIT"
}
