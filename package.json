{
  "name": "chainq",
  "version": "0.0.0",
  "private": true,
  "description": "Self-hosted onchain analytics, agent-native. The OSS answer to Dune.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0"
  },
  "keywords": [
    "blockchain",
    "onchain",
    "analytics",
    "mcp",
    "ai-agent",
    "claude",
    "duckdb",
    "dbt",
    "dune-alternative"
  ]
}
